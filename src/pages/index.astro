---
import Layout from '../layouts/Layout.astro';
import BrainCanvas from '../components/BrainCanvas.svelte';
import SobrietyCounter from '../components/SobrietyCounter.svelte';
---

<Layout title="ShaneBrain — Local AI for the 800M left behind">
  <BrainCanvas client:only="svelte" />

  <div class="scan-line" aria-hidden="true"></div>

  <nav>
    <a href="/" class="nav-brand"><span class="sb">SB</span></a>
    <div class="nav-links">
      <a href="#ecosystem">Ecosystem</a>
      <a href="/login" class="nav-signin">Sign In</a>
    </div>
  </nav>

  <main>
    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">
          <span class="dot"></span>
          NEURAL INTELLIGENCE PLATFORM
        </p>

        <h1 class="wordmark">
          Shane<em>Brain</em>
        </h1>

        <p class="tagline">
          Local AI for the<br />
          <span class="tagline-bold">800 million left behind.</span>
        </p>

        <SobrietyCounter client:only="svelte" />

        <div class="ctas">
          <a href="/login" class="btn-primary">
            Access the Brain
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#ecosystem" class="btn-ghost">Explore Ecosystem</a>
        </div>

        <div class="chips">
          <div class="chip"><span class="chip-dot green"></span>13,726 RAG objects</div>
          <div class="chip"><span class="chip-dot cyan"></span>44 MCP tools</div>
          <div class="chip"><span class="chip-dot violet"></span>25 Weaviate collections</div>
        </div>
      </div>
    </section>

    <section class="ecosystem" id="ecosystem">
      <div class="section-head">
        <div class="rule"></div>
        <span>THE ECOSYSTEM</span>
        <div class="rule"></div>
      </div>

      <div class="eco-grid">
        <a href="https://mega.shanebrain.cloud" target="_blank" rel="noopener" class="eco-card">
          <span class="eco-num">01</span>
          <h3>MEGA Crew</h3>
          <p>AI comic universe — 51 panels, 7 episodes. A crew of bots writing their own mythology.</p>
          <span class="eco-arrow">→</span>
        </a>

        <a href="https://shanebrain.cloud" target="_blank" rel="noopener" class="eco-card">
          <span class="eco-num">02</span>
          <h3>Angel Cloud</h3>
          <p>Wellness platform and AI gateway — registration, chat, community, the soul of the network.</p>
          <span class="eco-arrow">→</span>
        </a>

        <div class="eco-card muted">
          <span class="eco-num">03</span>
          <h3>Claim Cruncher</h3>
          <p>Medical billing intake platform built for Gavin — Python + FastAPI on the same local stack.</p>
          <span class="eco-tag">IN DEV</span>
        </div>

        <a href="https://thebardchat.github.io/BGKPJR-Launch-Vis" target="_blank" rel="noopener" class="eco-card">
          <span class="eco-num">04</span>
          <h3>BGKPJR</h3>
          <p>EM launch simulations and NASA-ready 3D orbital visualizer — Astro + Three.js in deep space.</p>
          <span class="eco-arrow">→</span>
        </a>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="sb small">SB</span>
        <span class="footer-name">ShaneBrain</span>
      </div>
      <div class="footer-links">
        <a href="https://github.com/thebardchat" target="_blank" rel="noopener">GitHub</a>
        <a href="https://claude.ai/referral/4fAMYN9Ing" target="_blank" rel="noopener">Built with Claude</a>
        <a href="/login">Sign In</a>
      </div>
      <p class="footer-credit">
        Built by Shane Brazelton + Claude Anthropic ·
        <a href="https://claude.ai/referral/4fAMYN9Ing" target="_blank" rel="noopener">Try Claude free →</a>
      </p>
    </div>
  </footer>
</Layout>

<style>
  /* Scan line */
  .scan-line {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--cyan) 50%, transparent 100%);
    opacity: 0.25;
    z-index: 200;
    animation: scanMove 10s linear infinite;
    pointer-events: none;
  }

  /* Nav */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 2.5rem;
    background: linear-gradient(to bottom, rgba(3,7,18,0.85) 0%, transparent 100%);
    backdrop-filter: blur(6px);
  }

  .sb {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--cyan);
    background: var(--cyan-dim);
    border: 1px solid rgba(0,212,255,0.25);
    padding: 0.3rem 0.55rem;
    letter-spacing: 0.08em;
    transition: background 0.2s;
  }
  .sb:hover { background: rgba(0,212,255,0.2); }
  .sb.small { font-size: 0.75rem; padding: 0.22rem 0.4rem; }

  .nav-brand { display: flex; }
  .nav-links { display: flex; align-items: center; gap: 1.75rem; }
  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); opacity: 1; }
  .nav-signin {
    color: var(--cyan) !important;
    border: 1px solid rgba(0,212,255,0.25);
    padding: 0.35rem 0.9rem;
  }
  .nav-signin:hover { background: var(--cyan-dim); }

  /* Hero */
  main { position: relative; z-index: 10; }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2.5rem 4rem;
  }

  .hero-inner {
    max-width: 760px;
    animation: fadeInUp 0.7s ease both;
  }

  .eyebrow {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    color: var(--text-dim);
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.7s ease 0.1s both;
  }

  .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 10px var(--cyan);
    flex-shrink: 0;
    animation: glowPulse 2s ease-in-out infinite;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: clamp(3.75rem, 9vw, 7.5rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1.4rem;
    animation: fadeInUp 0.7s ease 0.15s both;
  }

  .wordmark em {
    color: var(--cyan);
    font-style: normal;
    text-shadow:
      0 0 30px rgba(0,212,255,0.4),
      0 0 80px rgba(0,212,255,0.12);
    animation: glowPulse 3.5s ease-in-out infinite;
  }

  .tagline {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2.5vw, 1.55rem);
    font-weight: 300;
    color: var(--text-dim);
    line-height: 1.45;
    animation: fadeInUp 0.7s ease 0.22s both;
  }

  .tagline-bold {
    color: var(--text);
    font-weight: 500;
    font-style: italic;
  }

  /* CTAs */
  .ctas {
    display: flex;
    gap: 0.9rem;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 2.5rem;
    animation: fadeInUp 0.7s ease 0.4s both;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--cyan);
    color: var(--bg) !important;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.85rem 1.65rem;
    clip-path: polygon(0 0, calc(100% - 7px) 0, 100% 7px, 100% 100%, 7px 100%, 0 calc(100% - 7px));
    transition: all 0.2s !important;
  }
  .btn-primary:hover {
    background: #fff;
    opacity: 1 !important;
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(0,212,255,0.35);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    padding: 0.85rem 1.65rem;
    border: 1px solid var(--glass-border);
    color: var(--text-dim) !important;
    transition: all 0.2s !important;
  }
  .btn-ghost:hover {
    border-color: rgba(0,212,255,0.4);
    color: var(--cyan) !important;
    opacity: 1 !important;
  }

  /* Data chips */
  .chips {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 2.25rem;
    animation: fadeInUp 0.7s ease 0.5s both;
  }

  .chip {
    display: flex;
    align-items: center;
    gap: 0.38rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    color: var(--text-dim);
    background: var(--glass);
    border: 1px solid var(--glass-border);
    padding: 0.28rem 0.7rem;
  }

  .chip-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .chip-dot.green  { background: var(--emerald); box-shadow: 0 0 6px var(--emerald); }
  .chip-dot.cyan   { background: var(--cyan);    box-shadow: 0 0 6px var(--cyan); }
  .chip-dot.violet { background: #a78bfa;        box-shadow: 0 0 6px #a78bfa; }

  /* Ecosystem */
  .ecosystem {
    padding: 6rem 2.5rem 8rem;
    max-width: 1180px;
    margin: 0 auto;
    width: 100%;
  }

  .section-head {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 2.75rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .rule {
    flex: 1;
    height: 1px;
    background: var(--glass-border);
  }

  .eco-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    border: 1px solid var(--glass-border);
    gap: 1px;
    background: var(--glass-border);
  }

  .eco-card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding: 2rem 1.75rem;
    background: var(--bg);
    color: var(--text) !important;
    position: relative;
    overflow: hidden;
    transition: background 0.25s !important;
    cursor: pointer;
  }

  .eco-card::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--cyan), var(--violet));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .eco-card:not(.muted):hover { background: rgba(0,212,255,0.025); opacity: 1 !important; }
  .eco-card:not(.muted):hover::after { opacity: 1; }
  .eco-card.muted { opacity: 0.45; cursor: default; }

  .eco-num {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--cyan);
    letter-spacing: 0.12em;
  }

  .eco-card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text);
  }

  .eco-card p {
    font-size: 0.83rem;
    color: var(--text-dim);
    line-height: 1.65;
    flex: 1;
  }

  .eco-arrow {
    font-size: 1rem;
    color: var(--cyan);
    transition: transform 0.2s;
  }
  .eco-card:hover .eco-arrow { transform: translateX(4px); }

  .eco-tag {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    color: #a78bfa;
    border: 1px solid rgba(124,58,237,0.35);
    padding: 0.18rem 0.45rem;
    width: fit-content;
  }

  /* Footer */
  footer {
    position: relative;
    z-index: 10;
    border-top: 1px solid var(--glass-border);
    padding: 1.75rem 2.5rem;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    max-width: 1180px;
    margin: 0 auto;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 0.88rem;
    color: var(--text-dim);
  }

  .footer-links {
    display: flex;
    gap: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
  }

  .footer-links a { color: var(--text-dim); }
  .footer-links a:hover { color: var(--cyan); opacity: 1; }

  .footer-credit {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--text-dim);
  }

  .footer-credit a { color: var(--cyan); }

  @media (max-width: 640px) {
    nav { padding: 1rem 1.25rem; }
    .hero { padding: 6rem 1.25rem 3rem; }
    .ecosystem { padding: 4rem 1.25rem 5rem; }
    footer { padding: 1.5rem 1.25rem; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
